{
  "version": 2,
  "name": "nze-miel",
  "buildCommand": null,
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/outil", "dest": "/outil/login.html" },
    { "src": "/outil/(.*)", "dest": "/outil/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
